rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── Users ───────────────────────────────────────────────────────────────
    // Each user can read and update their own profile document.
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      // Personal emergency contacts sub-collection
      match /contacts/{contactId} {
        allow read, create, update, delete: if isOwner(uid);
      }
    }

    // ── Incidents ───────────────────────────────────────────────────────────
    // Any authenticated user can create an incident.
    // Users can only read or update their own incidents.
    match /incidents/{incidentId} {
      allow create: if isSignedIn()
                    && request.resource.data.userId == request.auth.uid;

      allow read, update: if isSignedIn()
                          && resource.data.userId == request.auth.uid;
    }

    // ── Emergency hotlines ──────────────────────────────────────────────────
    // Any authenticated user can read hotlines.
    // Write access is intentionally restricted (admin-only via console).
    match /emergency_hotlines/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
